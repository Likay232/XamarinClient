@{
    ViewBag.Title = "Главная";
    Layout = "_ClientLayout";
}

<style>
    .home-container {
        max-width: 1000px;
        margin: 60px auto;
        padding: 0 20px;
        text-align: center;
    }

    .home-title {
        font-size: 32px;
        margin-bottom: 10px;
    }

    .home-subtitle {
        color: #666;
        margin-bottom: 40px;
    }

    .nav-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 25px;
    }

    .nav-card {
        background: #fff;
        border-radius: 14px;
        padding: 30px 20px;
        text-decoration: none;
        color: #333;
        box-shadow: 0 6px 16px rgba(0,0,0,0.08);
        transition: all 0.2s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
    }

    .nav-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 22px rgba(0,0,0,0.12);
    }

    .nav-icon {
        font-size: 40px;
    }

    .nav-title {
        font-size: 18px;
        font-weight: 600;
    }

    .nav-desc {
        font-size: 14px;
        color: #777;
    }
</style>

<div class="home-container">
    <div class="home-subtitle">
        Выберите раздел для начала обучения
    </div>

    <div class="nav-grid">

        <!-- Профиль -->
        <a href="/ClientMvc/ProfileInfo" class="nav-card">
            <div class="nav-icon">👤</div>
            <div class="nav-title">Профиль</div>
            <div class="nav-desc">
                Ваш прогресс, статистика и результаты
            </div>
        </a>

        <!-- Темы -->
        <a href="/ClientMvc/Themes" class="nav-card">
            <div class="nav-icon">📚</div>
            <div class="nav-title">Темы</div>
            <div class="nav-desc">
                Теория и материалы по билетам ПДД
            </div>
        </a>

        <!-- Практика -->
        <a href="/ClientMvc/TestVariants" class="nav-card">
            <div class="nav-icon">📝</div>
            <div class="nav-title">Практика</div>
            <div class="nav-desc">
                Решение билетов и режим экзамена
            </div>
        </a>

    </div>
</div>