@{
    Layout = "_AdminLayout";
}

<style>
    .admin-container {
        max-width: 1000px;
        margin: 60px auto;
        padding: 0 20px;
        text-align: center;
    }

    .admin-title {
        font-size: 32px;
        margin-bottom: 10px;
    }

    .admin-subtitle {
        color: #666;
        margin-bottom: 40px;
    }

    .admin-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 25px;
    }

    .admin-card {
        background: #fff;
        border-radius: 14px;
        padding: 30px 20px;
        text-decoration: none;
        color: #333;
        box-shadow: 0 6px 16px rgba(0,0,0,0.08);
        transition: all 0.2s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        border-top: 4px solid transparent;
    }

    .admin-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 22px rgba(0,0,0,0.12);
    }

    /* Разные акценты */
    .admin-users {
        border-top-color: #5cb85c;
    }

    .admin-themes {
        border-top-color: #0275d8;
    }

    .admin-icon {
        font-size: 42px;
    }

    .admin-card-title {
        font-size: 18px;
        font-weight: 600;
    }

    .admin-card-desc {
        font-size: 14px;
        color: #777;
        text-align: center;
    }
</style>

<div class="admin-container">
    <div class="admin-title">
        Панель администратора
    </div>


    <div class="admin-grid">

        <!-- Пользователи -->
        <a href="/Admin/Users" class="admin-card admin-users">
            <div class="admin-icon">👥</div>
            <div class="admin-card-title">Пользователи</div>
            <div class="admin-card-desc">
                Просмотр и редактирование пользователей
            </div>
        </a>

        <!-- Темы -->
        <a href="/Admin/Themes" class="admin-card admin-themes">
            <div class="admin-icon">🗂️</div>
            <div class="admin-card-title">Темы и материалы</div>
            <div class="admin-card-desc">
                Редактирование тем, заданий и учебных материалов
            </div>
        </a>

    </div>
</div>